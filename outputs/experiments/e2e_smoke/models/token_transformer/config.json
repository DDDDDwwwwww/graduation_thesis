{
  "dataset": "outputs\\experiments\\e2e_smoke\\datasets\\tictactoe_30.jsonl",
  "encoder": "board_token",
  "model": "transformer",
  "epochs": 2,
  "batch_size": 64,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "seed": 42,
  "hidden_dims": [
    256,
    128
  ],
  "dropout": 0.1,
  "loss": "mse",
  "patience": 5,
  "device": "cpu",
  "roles": [
    "oplayer",
    "xplayer"
  ],
  "num_samples": 440,
  "position_mode": "index",
  "num_tokens": 4,
  "d_model": 128,
  "n_heads": 4,
  "n_layers": 3,
  "dim_feedforward": 256,
  "position_encoding": "sinusoidal",
  "max_positions": 4096,
  "use_global_features": true,
  "global_feature_dim": 3
}