;; Players and helpers
(opponent black white)
(opponent white black)
(same_player black black)
(same_player white white)
(<= (same_cell ?x ?y ?x ?y) (index ?x) (index ?y))
(<= (different_cell ?x1 ?y1 ?x2 ?y2) (index ?x1) (index ?y1) (index ?x2) (index ?y2) (not (same_cell ?x1 ?y1 ?x2 ?y2)))
(<= (same_num ?n ?n) (num ?n))

;; 8 directions
(<= (adj_dir ?x ?y ?nx ?y east) (succ ?x ?nx) (index ?y))
(<= (adj_dir ?x ?y ?nx ?y west) (succ ?nx ?x) (index ?y))
(<= (adj_dir ?x ?y ?x ?ny south) (index ?x) (succ ?y ?ny))
(<= (adj_dir ?x ?y ?x ?ny north) (index ?x) (succ ?ny ?y))
(<= (adj_dir ?x ?y ?nx ?ny southeast) (succ ?x ?nx) (succ ?y ?ny))
(<= (adj_dir ?x ?y ?nx ?ny northwest) (succ ?nx ?x) (succ ?ny ?y))
(<= (adj_dir ?x ?y ?nx ?ny northeast) (succ ?x ?nx) (succ ?ny ?y))
(<= (adj_dir ?x ?y ?nx ?ny southwest) (succ ?nx ?x) (succ ?y ?ny))

;; Initial state (official opening)
(init (control black))
(init (cell 1 1 empty))
(init (cell 1 2 empty))
(init (cell 1 3 empty))
(init (cell 1 4 empty))
(init (cell 1 5 empty))
(init (cell 1 6 empty))
