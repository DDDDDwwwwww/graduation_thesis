(next_pos 6 8 7 8)
(next_pos 7 8 8 8)

;; Disc counting via aggregate (Prolog builtin, equivalent semantics)
(<= (disc_count black ?n)
    (aggregate_all count (true (cell ?x ?y black)) ?n))

(<= (disc_count white ?n)
    (aggregate_all count (true (cell ?x ?y white)) ?n))
