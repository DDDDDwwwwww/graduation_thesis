(init (cell 8 5 empty))
(init (cell 8 6 empty))
(init (cell 8 7 empty))
(init (cell 8 8 empty))

;; A line is capturable if from first opponent disc you can eventually reach own disc
(<= (line_to_player ?p ?x ?y ?d)
    (adj_dir ?x ?y ?x2 ?y2 ?d)
    (true (cell ?x2 ?y2 ?p)))

(<= (line_to_player ?p ?x ?y ?d)
    (adj_dir ?x ?y ?x2 ?y2 ?d)
    (true (cell ?x2 ?y2 ?opp))
    (opponent ?p ?opp)
    (line_to_player ?p ?x2 ?y2 ?d))

(<= (capture_line ?p ?x ?y ?d)
    (adj_dir ?x ?y ?x1 ?y1 ?d)
    (true (cell ?x1 ?y1 ?opp))
    (opponent ?p ?opp)
    (line_to_player ?p ?x1 ?y1 ?d))

;; Move candidates independent of turn
(<= (possible_move ?p ?x ?y)
    (true (cell ?x ?y empty))
    (capture_line ?p ?x ?y ?d))

(<= (can_move ?p) (possible_move ?p ?x ?y))

;; Legal moves
(<= (legal ?p (place ?x ?y))
    (true (control ?p))
    (possible_move ?p ?x ?y))

(<= (legal ?p pass)
    (true (control ?p))
    (not (can_move ?p)))

(<= (legal white noop) (true (control black)))
(<= (legal black noop) (true (control white)))

;; Discs to flip for a concrete move
(<= (flip_chain ?p ?cx ?cy ?d ?cx ?cy)
    (line_to_player ?p ?cx ?cy ?d))

(<= (flip_chain ?p ?cx ?cy ?d ?fx ?fy)
    (adj_dir ?cx ?cy ?nx ?ny ?d)
    (true (cell ?nx ?ny ?opp))
    (opponent ?p ?opp)
    (flip_chain ?p ?nx ?ny ?d ?fx ?fy))

(<= (to_flip ?p ?mx ?my ?fx ?fy)
    (adj_dir ?mx ?my ?x1 ?y1 ?d)
    (true (cell ?x1 ?y1 ?opp))
    (opponent ?p ?opp)
    (flip_chain ?p ?x1 ?y1 ?d ?fx ?fy))

;; Next control
(<= (next (control black)) (true (control white)))
(<= (next (control white)) (true (control black)))

;; Next cells: placed disc and flipped discs
(<= (next (cell ?x ?y ?p))
    (does ?p (place ?x ?y)))

(<= (next (cell ?fx ?fy ?p))
    (does ?p (place ?mx ?my))
    (to_flip ?p ?mx ?my ?fx ?fy))

;; Frame for normal placement
(<= (next (cell ?x ?y ?s))
    (true (cell ?x ?y ?s))
    (does ?p (place ?mx ?my))
    (different_cell ?x ?y ?mx ?my)
    (not (to_flip ?p ?mx ?my ?x ?y)))

;; Frame for pass
(<= (next (cell ?x ?y ?s))
    (true (cell ?x ?y ?s))
    (does ?p pass))

;; Terminal: board full OR neither player has a legal placement
(<= has_empty
    (true (cell ?x ?y empty)))

(<= terminal
    (not has_empty))

(<= terminal
    (not (can_move black))
    (not (can_move white)))

;; Position order for counting (row-major: x then y)
(next_pos 1 1 2 1)
(next_pos 2 1 3 1)
(next_pos 3 1 4 1)
(next_pos 4 1 5 1)
(next_pos 5 1 6 1)
