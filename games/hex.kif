;; Initial state
;; stage opening: white makes first move
;; stage opening_swap: black may swap (pie rule) or place
;; stage normal: regular alternating play
(init (control white))
(init (stage opening))

(init (cell 1 1 empty)) (init (cell 1 2 empty)) (init (cell 1 3 empty)) (init (cell 1 4 empty)) (init (cell 1 5 empty))
(init (cell 2 1 empty)) (init (cell 2 2 empty)) (init (cell 2 3 empty)) (init (cell 2 4 empty)) (init (cell 2 5 empty))
(init (cell 3 1 empty)) (init (cell 3 2 empty)) (init (cell 3 3 empty)) (init (cell 3 4 empty)) (init (cell 3 5 empty))
(init (cell 4 1 empty)) (init (cell 4 2 empty)) (init (cell 4 3 empty)) (init (cell 4 4 empty)) (init (cell 4 5 empty))
(init (cell 5 1 empty)) (init (cell 5 2 empty)) (init (cell 5 3 empty)) (init (cell 5 4 empty)) (init (cell 5 5 empty))

;; Legal moves
(<= (legal ?player (place ?x ?y))
    (true (control ?player))
    (true (cell ?x ?y empty)))

;; Pie rule: only black can swap, only immediately after white first move.
(<= (legal black swap)
    (true (control black))
    (true (stage opening_swap)))

;; Turn-based no-op
(<= (legal white noop)
    (true (control black)))

(<= (legal black noop)
    (true (control white)))

;; Stage transitions
(<= (next (stage opening_swap))
    (true (stage opening))
    (does white (place ?x ?y)))

(<= (next (stage normal))
    (true (stage opening_swap))
    (does black swap))

(<= (next (stage normal))
    (true (stage opening_swap))
    (does black (place ?x ?y)))

(<= (next (stage normal))
    (true (stage normal)))

;; Control transitions
(<= (next (control black))
    (true (stage opening))
    (does white (place ?x ?y)))

(<= (next (control white))
    (true (stage opening_swap))
    (does black swap))

(<= (next (control white))
    (true (stage opening_swap))
    (does black (place ?x ?y)))

(<= (next (control white))
    (true (stage normal))
    (true (control black)))

(<= (next (control black))
    (true (stage normal))
    (true (control white)))

;; Record white first move for potential swap
(<= (next (first_move ?x ?y))
    (true (stage opening))
    (does white (place ?x ?y)))

;; Cell updates for place
(<= (next (cell ?x ?y white))
    (does white (place ?x ?y)))

(<= (next (cell ?x ?y black))
    (does black (place ?x ?y)))

;; Cell update for swap: the recorded first move becomes black
(<= (next (cell ?x ?y black))
    (does black swap)
    (true (first_move ?x ?y)))

;; Frame axioms
(<= (next (cell ?x ?y ?state))
    (true (cell ?x ?y ?state))
    (does ?player (place ?m ?n))
    (different_cell ?x ?y ?m ?n))

(<= (next (cell ?x ?y ?state))
    (true (cell ?x ?y ?state))
    (does black swap)
    (true (first_move ?m ?n))
    (different_cell ?x ?y ?m ?n))

