(<= (black_seen24 ?x ?y) (black_seen23 ?x ?y))
(<= (black_seen24 ?x ?y) (black_front24 ?x ?y))
(<= black_win (black_source ?xs) (black_target ?x) (black_seen24 ?x 5))

;; Terminal / goal
(<= terminal white_win)
(<= terminal black_win)

(<= (goal white 100) terminal white_win)
(<= (goal white 0) terminal black_win)
(<= (goal black 100) terminal black_win)
(<= (goal black 0) terminal white_win)

