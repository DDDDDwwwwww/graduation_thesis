;; ==========================================
;; 5x5 Hex (Official Rules Semantics + Pie Rule)
;; ==========================================

;; Roles
(role white)
(role black)

;; Board indices
(index 1) (index 2) (index 3) (index 4) (index 5)
(succ 1 2) (succ 2 3) (succ 3 4) (succ 4 5)

;; Helpers
(<= (same_index ?x ?x) (index ?x))

(<= (same_cell ?x ?y ?x ?y)
    (index ?x)
    (index ?y))

(<= (different_cell ?x1 ?y1 ?x2 ?y2)
    (index ?x1) (index ?y1)
    (index ?x2) (index ?y2)
    (not (same_cell ?x1 ?y1 ?x2 ?y2)))

;; Hex adjacency (explicit 5x5 facts)
(adjacent 1 1 2 1)
(adjacent 1 1 1 2)
(adjacent 1 2 2 2)
(adjacent 1 2 1 3)
(adjacent 1 2 1 1)
